    "vitest": "^4.0.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/CCF-Ledger-Explorer.git",
    "directory": "packages/ledger-parser"
  },
  "keywords": [
    "ccf",
