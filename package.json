    "@sqlite.org/sqlite-wasm": "^3.50.1-build1",
    "@tanstack/react-query": "^5.81.5",
    "@types/jsrsasign": "^10.5.15",
    "buffer": "^6.0.3",
    "cbor2": "^2.0.1",
    "js-base64": "^3.7.7",
