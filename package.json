{
  "name": "@microsoft/ccf-ledger-explorer",
  "private": false,
  "version": "1.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/CCF-Ledger-Explorer.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:packages && vite",
    "build": "npm run build:packages && tsc -b && vite build",
    "build:packages": "npm run build -w @microsoft/ccf-ledger-parser && npm run build -w @microsoft/ccf-database",
    "build:parser": "npm run build -w @microsoft/ccf-ledger-parser",
    "build:database": "npm run build -w @microsoft/ccf-database",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:parser": "npm run test -w @microsoft/ccf-ledger-parser"
  },
  "dependencies": {
    "@azure-rest/confidential-ledger": "1.1.2-beta.3",
    "@azure/storage-file-share": "^12.30.0",
    "@microsoft/ccf-database": "*",
    "@microsoft/ccf-ledger-parser": "*",
    "@fluentui/react-components": "^9.72.2",
    "@fluentui/react-icons": "^2.0.318",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.81.5",
    "@types/jsrsasign": "^10.5.15",
    "buffer": "^6.0.3",
    "cbor2": "^2.0.1",
    "js-base64": "^3.7.7",
    "jsrsasign": "^11.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.30.1",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "jsdom": "^26.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.8",
    "workbox-window": "^7.4.0"
  }
}
